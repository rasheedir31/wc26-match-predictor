# Copy to `.env` and adjust. All values have sane defaults in src/wc26/config.py;
# everything here is optional. `.env` is gitignored.

# --- Local Postgres warehouse (local only - never deployed; see the README) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wc26
POSTGRES_PASSWORD=wc26
POSTGRES_DB=wc26

# --- MLflow experiment tracking ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=wc26

# --- App (FastAPI + Streamlit) ---
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501

# --- Model / simulation hyperparameters (prefix WC26_MODEL_) ---
# WC26_MODEL_RANDOM_SEED=42
# WC26_MODEL_ELO_K=32
# WC26_MODEL_SIMULATION_RUNS=10000

# --- Data source overrides (prefix WC26_SOURCE_) ---
# WC26_SOURCE_RESULTS_URL=https://raw.githubusercontent.com/martj42/international_results/master/results.csv

# --- football-data.org (optional live WC26 results source for the monitor) ---
# Free token: https://www.football-data.org/client/register (World Cup is in the
# free tier). Leave empty to use the martj42 dataset instead. NEVER commit it.
FOOTBALL_DATA_TOKEN=
